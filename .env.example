# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# ---------------------------------------------------------------------
# Supabase (safe to expose to the browser — the anon key is public by design,
# protected by Row-Level Security policies on the database)
# ---------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------
# Anthropic API — SERVER-SIDE ONLY
# Read by the Vercel serverless function in /api/plan.js.
# Do NOT prefix with VITE_ — that would bundle it into the frontend bundle.
# ---------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Model is configurable so it's easy to change without code edits.
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---------------------------------------------------------------------
# Optional: only needed if you later add server-side admin operations
# (e.g. a cron job that reprioritizes plans). NOT used by /api/plan.js
# today — the function scopes all DB access through the user's own JWT.
# ---------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=
